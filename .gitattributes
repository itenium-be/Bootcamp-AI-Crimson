# Normalize all text files to CRLF on checkout (Windows development)
* text=auto eol=crlf

# Shell scripts must use LF to run on Linux (CI runners)
*.sh text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.dll binary
*.exe binary
